# Database (db-query skill)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=your_database

# Alibaba Cloud SLS (sls-query skill)
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
SLS_ENDPOINT=us-east-1.log.aliyuncs.com
SLS_PROJECT=your_default_project
SLS_TEST_PROJECT=k8s-log-xxxxx-test-cluster-id
SLS_PROD_PROJECT=k8s-log-xxxxx-prod-cluster-id

# Codeup Git (git-ops skill)
CODEUP_TOKEN=your_codeup_personal_access_token
CODEUP_ORG_ID=your_organization_id
GIT_WORKSPACE=./repos

# Jenkins (jenkins-deploy skill)
JENKINS_URL=http://127.0.0.1:8080/
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token
JENKINS_CLI_REMEMBER_PARAMS=true
