# Database (db-query skill)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=your_database

# Alibaba Cloud SLS (sls-query skill)
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
SLS_PROJECT=your_project_name
SLS_LOGSTORE=your_default_logstore

# Git (git-ops skill)
GIT_BASE_URL=https://codeup.aliyun.com
GIT_TOKEN=your_personal_access_token
GIT_WORKSPACE=./repos

# Jenkins (jenkins-deploy skill)
JENKINS_URL=http://127.0.0.1:8080/
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token
JENKINS_CLI_REMEMBER_PARAMS=true
